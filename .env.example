COMPOSE_PROJECT_NAME=shopapp

FRONTEND_PORT=4200
BACKEND_PORT=8081
KEYCLOAK_PORT=8080
KEYCLOAK_DB_PORT=5432

KEYCLOAK_DB_DATABASE=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak

KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin

APP_KEYCLOAK_REALM=demo
APP_KEYCLOAK_CLIENT_ID=my-app
# Optional: JWT issuer host (defaults in compose to http://localhost:${KEYCLOAK_PORT})
# APP_KEYCLOAK_PUBLIC_URL=http://localhost:8080
